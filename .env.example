THENVOI_REST_URL=https://app.band.ai/
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# AI/ML API (Org A: intake + adjudicator)
AIML_API_KEY=
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_MODEL=gpt-4o

# Featherless (Org B: specialist reviewers — property / medical / legal)
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
# Vision model for Evidence Analyst (distinct from text FEATHERLESS_MODEL).
# Must be an ungated VL model on your Featherless org. google/gemma-3-* are
# HuggingFace-gated (403 model_gated_needs_oauth); gemma-4-31B-it is open.
FEATHERLESS_VISION_MODEL=google/gemma-4-31B-it

# Demo seed: human reviewer user UUID (Org A Band account owner or reviewer user)
HUMAN_REVIEWER_USER_ID=
# Optional: user API key for dashboard approve/deny buttons
HUMAN_REVIEWER_USER_API_KEY=

# Gateway
GATEWAY_PORT=8080
GATEWAY_POLL_SECONDS=1.5
# Per-IP hourly cap on POST /api/seed (public demo guardrail)
SEED_CAP_PER_HOUR=30
